pair F2 = (2.6457513110645907, 0.0);

real d1_x = -6.047431568147635;
real d2_x = 6.047431568147635;

int n_check = 8;
real[] x_check = {4.0, 2.8284271247461903, 2.4492935982947064e-16, -2.82842712474619, -4.0, -2.8284271247461916, -7.347880794884119e-16, 2.828427124746187};
real[] y_check = {0.0, 2.1213203435596424, 3.0, 2.121320343559643, 3.6739403974420594e-16, -2.1213203435596415, -3.0, -2.121320343559645};
real[] ratio1 = {0.6614378277661477, 0.6614378277661478, 0.6614378277661477, 0.6614378277661478, 0.6614378277661478, 0.6614378277661477, 0.6614378277661477, 0.6614378277661478};
